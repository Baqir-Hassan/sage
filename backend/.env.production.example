APP_NAME=Notes to Lecture API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
VERIFICATION_TOKEN_EXPIRE_MINUTES=60
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://localhost:6379/0
QUEUE_PROVIDER=sqs
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/sage-document-processing
SQS_REGION=us-east-1
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=1
STORAGE_PROVIDER=s3
FRONTEND_ORIGINS=https://your-frontend-domain.com
FRONTEND_ORIGIN_REGEX=
LOCAL_STORAGE_PATH=./storage
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=
S3_BUCKET_RAW=
S3_BUCKET_AUDIO=
S3_BUCKET_ARTIFACTS=
S3_PRESIGN_EXPIRY_SECONDS=3600
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_MALE_VOICE=en-US-AndrewNeural
DEFAULT_FEMALE_VOICE=en-US-JennyNeural
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@sageai.live
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM_EMAIL=no-reply@sageai.live
VERIFY_EMAIL_PAGE_URL=https://sageai.live/verify-email
