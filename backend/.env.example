APP_NAME=Notes to Lecture API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440
VERIFICATION_TOKEN_EXPIRE_MINUTES=60
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
DATABASE_URL=sqlite:///./app.db
REDIS_URL=redis://localhost:6379/0
QUEUE_PROVIDER=celery
SQS_QUEUE_URL=
SQS_REGION=
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=1
STORAGE_PROVIDER=local
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
FRONTEND_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
LOCAL_STORAGE_PATH=./storage
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=
S3_BUCKET_RAW=notes-audio-raw
S3_BUCKET_AUDIO=notes-audio-audio
S3_BUCKET_ARTIFACTS=notes-audio-artifacts
S3_PRESIGN_EXPIRY_SECONDS=3600
GROQ_API_KEY=change-me
GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_MALE_VOICE=en-US-AndrewNeural
DEFAULT_FEMALE_VOICE=en-US-JennyNeural
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@sageai.live
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=no-reply@sageai.live
VERIFY_EMAIL_PAGE_URL=https://sageai.live/verify-email
